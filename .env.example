# APT Mining Workbench — Environment Variables Template
# Copy this file to .env and fill in actual values.
# This file IS safe to commit to version control.

# Database credentials (separate users with isolated permissions)
# Prod: apt_prod can only access apt_mining_prod
# Test: apt_test can only access apt_mining_test
APT_DB_USER_PROD=apt_prod
APT_DB_PASSWORD_PROD=change_me
APT_DB_USER_TEST=apt_test
APT_DB_PASSWORD_TEST=change_me

# Database connection (optional — default: 127.0.0.1:5432)
# APT_DB_HOST_PROD=127.0.0.1
# APT_DB_PORT_PROD=5432
# APT_DB_NAME_PROD=apt_mining_prod
# APT_DB_HOST_TEST=127.0.0.1
# APT_DB_PORT_TEST=5432
# APT_DB_NAME_TEST=apt_mining_test

# Server (optional overrides)
# APT_SERVER_HOST=127.0.0.1
# APT_SERVER_PORT=8088
# APT_AUTO_OPEN_BROWSER=1
